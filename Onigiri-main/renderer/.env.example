# ─── MindForge Environment Variables ───────────────────────
#
# DEMO MODE: Leave these as placeholder values to run in demo mode.
# The app will auto-detect missing credentials and use mock data.
#
# PRODUCTION: Replace with your real Supabase project credentials
# for persistent auth and analytics.

# ─── Supabase (required for Auth + Analytics) ──────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Only needed when running locally with Electron backend ─
# VITE_ROOM_SERVER=http://localhost:39871
# GROQ_API_KEY=your_groq_api_key
